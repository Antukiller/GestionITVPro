<Page x:Class="GestionITVPro.WPF.Views.Backup.BackupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Gestión de Datos"
      Background="#0A0A0C">

    <Page.Resources>
        <Style x:Key="ResidentButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Background" Value="#1A1A23"/>
            <Setter Property="Foreground" Value="#00F2FF"/> <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#25252D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#00F2FF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#16161D" BorderBrush="#25252D" BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <Ellipse Width="40" Height="40" Fill="#00F2FF" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#00F2FF" BlurRadius="10" ShadowDepth="0"/>
                    </Ellipse.Effect>
                </Ellipse>
                
                <TextBlock Text="GESTIÓN ITV PRO" 
                           Foreground="White" 
                           FontSize="12" 
                           FontWeight="Black" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"/>
                
                <TextBlock Text="ADMINISTRACIÓN DE SISTEMA" 
                           Foreground="#666" 
                           FontSize="9" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                
                <Button Content="[ RESTAURAR DATOS ]" 
                        Style="{StaticResource ResidentButtonStyle}"
                        Command="{Binding RestaurarBackupCommand}"/>
                
                <Button Content="[ GENERAR BACKUP ]" 
                        Style="{StaticResource ResidentButtonStyle}"
                        Command="{Binding RealizarBackupCommand}"/>
                
                <Button Content="[ REFRESCAR LISTA ]" 
                        Style="{StaticResource ResidentButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
                
                <Separator Background="#25252D" Margin="0,20"/>
                
                <Button Content="[ ELIMINAR ARCHIVO ]" 
                        Style="{StaticResource ResidentButtonStyle}" 
                        Foreground="#FF4444" BorderBrush="#442222" Background="#221111"
                        Command="{Binding EliminarBackupsCommand}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="MANTENIMIENTO DE COPIAS" FontSize="24" FontWeight="Black" Foreground="White"/>
                <TextBlock Text="HISTORIAL DE SEGURIDAD DEL SISTEMA" FontSize="10" Foreground="#00F2FF" FontWeight="Bold"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#16161D" BorderBrush="#25252D" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <StackPanel Margin="15">
                        <TextBlock Text="> CONECTADO AL SERVIDOR DE DATOS..." Foreground="#00F2FF" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding StatusMessage, StringFormat='> ESTADO: {0}'}" Foreground="White" Opacity="0.7" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="SELECCIONE ARCHIVO PARA OPERAR:" Foreground="#888" FontSize="10" Margin="0,10,0,5"/>
                        
                        <ListBox ItemsSource="{Binding Backups}" 
                                 SelectedItem="{Binding SelectedBackup}"
                                 Background="Transparent" 
                                 Foreground="White" 
                                 BorderBrush="#25252D"
                                 Height="250">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                            <Setter Property="BorderBrush" Value="#00F2FF"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <ProgressBar IsIndeterminate="{Binding IsLoading}" 
                                     Width="200" Height="2" HorizontalAlignment="Left" 
                                     Margin="0,20,0,0" Background="Transparent" Foreground="#00F2FF" 
                                     BorderThickness="0"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="#444" FontSize="10" Margin="0,10,0,0" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Page>