<Page x:Class="GestionITVPro.WPF.Views.Dashboard.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Panel de Control de Citas"
      Background="#0F0F12">

    <Page.Resources>
        <!-- Estilo Gamer para Botones -->
        <Style x:Key="GamerActionButton" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#00F2FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#00F2FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00F2FF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- Usamos un Viewbox para que el contenido se adapte al tamaño de la ventana sin cortarse -->
    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
        <Grid Margin="30" Width="900">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Cabecera -->
                <RowDefinition Height="Auto" /> <!-- Card Principal -->
                <RowDefinition Height="Auto" /> <!-- Estadísticas y Acciones -->
            </Grid.RowDefinitions>

            <!-- 1. CABECERA -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                <Border Width="50" Height="50" Background="#00F2FF" CornerRadius="12" Margin="0,0,15,0">
                    <TextBlock Text="📅" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="CENTRO DE CONTROL" Foreground="White" FontSize="30" FontWeight="Black"/>
                    <TextBlock Text="Gestión Operativa de Citas ITV" Foreground="#555" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <!-- 2. CARD DE CITAS -->
            <Border Grid.Row="1" Background="#16161D" CornerRadius="20" Padding="25" Margin="0,0,0,25" 
                    BorderBrush="#333" BorderThickness="1">
                <Grid>
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Text="TOTAL DE CITAS" Foreground="#777" FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Informe.TotalCitas}" Foreground="White" FontSize="56" FontWeight="Bold">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00F2FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBlock Text="SISTEMA: ONLINE" Foreground="#00FF88" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding Informe.UltimaCitaProgramada, StringFormat='Ultima: {0:dd/MM/yy}'}" 
                                   Foreground="#555" FontSize="10" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. SECCIÓN INFERIOR: ESTADÍSTICAS Y ACCIONES -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Columna Izquierda: Estadísticas -->
                <Border Grid.Column="0" Background="#16161D" CornerRadius="20" Padding="20" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="ESTADÍSTICAS" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <!-- Completadas -->
                        <StackPanel Margin="0,0,0,15">
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="CITAS COMPLETADAS" Foreground="#AAA" FontSize="12"/>
                                <TextBlock Text="{Binding Informe.PorcentajeCompletadas, StringFormat={}{0:F0}%}" 
                                           Foreground="#00F2FF" FontSize="12" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Value="{Binding Informe.PorcentajeCompletadas}" Height="6" Foreground="#00F2FF" Background="#252525" BorderThickness="0"/>
                        </StackPanel>

                        <!-- Pendientes -->
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="PENDIENTES" Foreground="#AAA" FontSize="12"/>
                                <TextBlock Text="{Binding Informe.PorcentajePendientes, StringFormat={}{0:F0}%}" 
                                           Foreground="#FF0055" FontSize="12" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Value="{Binding Informe.PorcentajePendientes}" Height="6" Foreground="#FF0055" Background="#252525" BorderThickness="0"/>
                        </StackPanel>
                        
                        <!-- Mini Stats -->
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Hoy:" Foreground="#777" FontSize="12"/>
                                <TextBlock Text="{Binding Informe.CitasParaHoy}" Foreground="White" FontWeight="Bold" Margin="5,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Atrasadas:" Foreground="#777" FontSize="12"/>
                                <TextBlock Text="{Binding Informe.CitasAtrasadas}" Foreground="#FF0055" FontWeight="Bold" Margin="5,0,0,0"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Columna Derecha: Acciones -->
                <Border Grid.Column="1" Background="#1A1A23" CornerRadius="20" Padding="20">
                    <StackPanel VerticalAlignment="Stretch">
                        <TextBlock Text="ACCIONES" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                        
                        <Button Content="REFRESCAR 🔄" Command="{Binding RefrescarCommand}" Style="{StaticResource GamerActionButton}"/>
                        <Button Content="GRÁFICOS 📊" Command="{Binding VerGraficosCommand}" Style="{StaticResource GamerActionButton}" 
                                BorderBrush="#7000FF" Foreground="#7000FF" Background="#120B20"/>
                        
                        <Border Background="#252535" CornerRadius="10" Padding="10" Margin="0,10,0,0">
                            <TextBlock Text="LUIS VIVES ITV" Foreground="#555" FontSize="10" TextAlignment="Center" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</Page>