<Window x:Class="GestionITVPro.WPF.Views.AcercaDe.AcercaDe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Acerca de" Height="380" Width="450"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">

    <Border CornerRadius="15" BorderBrush="#25252D" BorderThickness="1" Background="#0A0A0C">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#16161D" Offset="0"/>
                    <GradientStop Color="#0A0A0C" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center" Margin="30">
                
                <TextBlock Text="AUTOR DEL SISTEMA" 
                           Foreground="#00F2FF" 
                           FontSize="10" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,5"/>

                <TextBlock Text="Antoine Amir López Jauregui" 
                           FontSize="22" 
                           FontWeight="Black" 
                           Foreground="White" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="White" BlurRadius="10" Opacity="0.2" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="Desarrollador de la 8ª maravilla" 
                           FontSize="14" 
                           Foreground="#888" 
                           FontStyle="Italic"
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30" />
                
                <Border Width="70" Height="70" Background="#1A1A23" CornerRadius="35" BorderBrush="#00F2FF" BorderThickness="1" Margin="0,0,0,25">
                    <iconPacks:PackIconMaterial Kind="Github" 
                                                Width="35" 
                                                Height="35" 
                                                Foreground="White" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                    <Border.Effect>
                        <DropShadowEffect Color="#00F2FF" BlurRadius="15" Opacity="0.4" ShadowDepth="0"/>
                    </Border.Effect>
                </Border>

                <Button Content="VER REPOSITORIO" 
                        Width="180" 
                        Height="40"
                        Background="#1A1A23"
                        Foreground="#00F2FF"
                        BorderBrush="#00F2FF"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="OnGitHubClick">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="1" 
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#00F2FF"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="CERRAR" 
                        Margin="0,15,0,0"
                        Background="Transparent" 
                        Foreground="White" 
                        BorderThickness="0"
                        FontSize="10"
                        Click="OnCerrarClick" 
                        Cursor="Hand"/>
                
            </StackPanel>
        </Grid>
    </Border>
</Window>