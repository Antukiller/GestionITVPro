<Page x:Class="GestionITVPro.WPF.Views.Cita.CitaView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Umbrella ITV - Panel de Control" 
      Background="#0A0A0C">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0: Header -->
            <RowDefinition Height="Auto" /> <!-- 1: Acciones Principales -->
            <RowDefinition Height="*" />    <!-- 2: Área de Trabajo -->
            <RowDefinition Height="Auto" /> <!-- 3: Paginación -->
            <RowDefinition Height="Auto" /> <!-- 4: Footer -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="SISTEMA DE INSPECCIÓN TÉCNICA" Foreground="#00F2FF" FontSize="11" FontWeight="ExtraBold" Margin="0,0,0,5"/>
            <TextBlock Text="GESTIÓN DE CITAS" Foreground="White" FontSize="32" FontWeight="Black"/>
            <Separator Background="#1A1A23" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- 2. TOOLBAR PRINCIPAL -->
        <Border Grid.Row="1" Background="#16161D" CornerRadius="10" Padding="15" Margin="0,0,0,20" BorderBrush="#222" BorderThickness="1">
            <DockPanel LastChildFill="False">
                <!-- Botones de Acción (Izquierda) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button x:Name="BtnNuevo" 
                            Command="{Binding NewCommand}"
                            Content="➕ NUEVO" Width="120" Height="40" Margin="0,0,20,0" Background="#00F2FF" Foreground="#0A0A0C" FontWeight="Black" Cursor="Hand" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                    </Button>
                    
                    <Button x:Name="BtnVer" 
                            Command="{Binding ViewCommand}"
                            Content="👁️ VER" Width="100" Height="40" Margin="0,0,20,0" Background="#1A1A23" Foreground="White" BorderBrush="#333" Cursor="Hand"/>
                    
                    <Button x:Name="BtnEditar" 
                            Command="{Binding EditCommand}"
                            Content="✏️ EDITAR" Width="100" Height="40" Margin="0,0,20,0" Background="#1A1A23" Foreground="White" BorderBrush="#333" Cursor="Hand"/>
                    
                    <Button x:Name="BtnEliminar" 
                            Command="{Binding DeleteCommand}"
                            Content="🗑️ ELIMINAR" Width="110" Height="40" Background="#1A1A23" Foreground="#FF0055" BorderBrush="#441122" Cursor="Hand"/>
                </StackPanel>

                <!-- Filtros y Búsqueda (Derecha) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Rectangle Width="1" Height="25" Fill="#333" Margin="20,0,25,0"/>
                    
                    <!-- Filtro Motor -->
                    <TextBlock Text="MOTOR:" Foreground="#555" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CbFiltroMotor" 
                              SelectedItem="{Binding SelectedMotorFilter}"
                              Width="130" Height="32" Background="#1A1A23" Foreground="White" BorderBrush="#333" Margin="0,0,20,0">
                        <!-- Nota: Estos items deberían cargarse preferiblemente desde el ViewModel si usas Enums -->
                        <ComboBoxItem Content="⚡ TODOS" IsSelected="True"/>
                        <ComboBoxItem Content="⛽ GASOLINA"/>
                        <ComboBoxItem Content="🛢️ DIÉSEL"/>
                        <ComboBoxItem Content="🔌 HÍBRIDO"/>
                        <ComboBoxItem Content="🔋 ELÉCTRICO"/>
                    </ComboBox>

                    <!-- Buscador -->
                    <TextBlock Text="🔍" Foreground="#555" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>
                    <TextBox x:Name="TxtBuscar" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="150" Height="32" Background="Transparent" Foreground="White" BorderBrush="#00F2FF" BorderThickness="0,0,0,1" VerticalContentAlignment="Center" Padding="5,0" />
                    
                    <!-- Recargar -->
                    <Button x:Name="BtnRefrescar" 
                            Command="{Binding LoadStatisticsCommand}"
                            Content="🔄 RECARGAR" Width="120" Height="35" Margin="25,0,0,0" Background="#1A1A23" Foreground="#00F2FF" BorderBrush="#00F2FF" Cursor="Hand" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 3. ÁREA DE TRABAJO -->
        <Grid Grid.Row="2">
            <Border Background="#0F0F12" CornerRadius="10" BorderBrush="#1A1A23" BorderThickness="1"/>

            <DockPanel>
                <!-- Toolbar de estado superior -->
                <Border x:Name="AcademicToolbar" DockPanel.Dock="Top" Background="#2200F2FF" BorderBrush="#00F2FF" BorderThickness="0,0,0,1" Padding="10,5"> 
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <!-- El ProgressBar puede ocultarse si no hay carga activa usando Visibility -->
                            <ProgressBar IsIndeterminate="True" Width="80" Height="2" VerticalAlignment="Center" Background="Transparent" Foreground="#00F2FF" BorderThickness="0"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#00F2FF" FontSize="10" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="SISTEMA LISTO" HorizontalAlignment="Right" Foreground="#00F2FF" FontSize="9" FontWeight="Black" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- TABLA DE DATOS (DataGrid) -->
                <DataGrid ItemsSource="{Binding Citas}" 
                          SelectedItem="{Binding SelectedCita}"
                          AutoGenerateColumns="False" 
                          Background="Transparent" 
                          Foreground="White"
                          BorderThickness="0" 
                          GridLinesVisibility="None"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#08080A"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          FontSize="13"
                          MouseDoubleClick="OnCitaDoubleClick">
                    
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#16161D"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#222"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MATRÍCULA" Binding="{Binding Matricula}" Width="1.2*"/>
                        <DataGridTextColumn Header="MARCA" Binding="{Binding Marca}" Width="*"/>
                        <DataGridTextColumn Header="MODELO" Binding="{Binding Modelo}" Width="*"/>
                        <DataGridTextColumn Header="MOTOR" Binding="{Binding Motor}" Width="0.8*"/>
                        <DataGridTextColumn Header="FECHA ITV" Binding="{Binding FechaItv, StringFormat=dd/MM/yyyy}" Width="*"/>
                        <DataGridTextColumn Header="INSPECCIÓN" Binding="{Binding FechaInspeccion, StringFormat=dd/MM/yyyy}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- 4. PAGINACIÓN -->
        <Border Grid.Row="3" Background="#16161D" CornerRadius="10" Padding="15,10" Margin="0,15,0,0" BorderBrush="#222" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding FirstPageCommand}" Content="⏮" Width="45" Height="35" Background="Transparent" Foreground="#00F2FF" BorderBrush="#333" Margin="0,0,8,0"/>
                <Button Command="{Binding PreviousPageCommand}" Content="◀" Width="45" Height="35" Background="Transparent" Foreground="#00F2FF" BorderBrush="#333" Margin="0,0,15,0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PÁGINA" Foreground="#555" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Border Background="#00F2FF" Margin="12,0" Padding="12,6" CornerRadius="4">
                        <TextBlock Text="{Binding CurrentPage}" Foreground="#0A0A0C" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="DE" Foreground="#555" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPages}" Foreground="White" Margin="12,0" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
                <Button Command="{Binding NextPageCommand}" Content="▶" Width="45" Height="35" Background="Transparent" Foreground="#00F2FF" BorderBrush="#333" Margin="15,0,8,0"/>
                <Button Command="{Binding LastPageCommand}" Content="⏭" Width="45" Height="35" Background="Transparent" Foreground="#00F2FF" BorderBrush="#333" Margin="0,0,25,0"/>
            </StackPanel>
        </Border>

        <!-- 5. FOOTER -->
        <Border Grid.Row="4" Margin="0,15,0,0">
            <Grid>
                <TextBlock Text="LUIS VIVES ITV - TERMINAL 01 v2.6" Foreground="#333" FontSize="10" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="8" Height="8" Fill="#00FF88" Margin="0,0,10,0"/>
                    <TextBlock Text="CONEXIÓN SEGURA" Foreground="#00FF88" FontSize="10" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>