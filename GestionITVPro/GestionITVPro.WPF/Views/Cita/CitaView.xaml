<Page x:Class="GestionITVPro.WPF.Views.Cita.CitaView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Umbrella ITV - Panel de Control" 
      Background="#0A0A0C">

    <Page.Resources>
        <Style TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <RowDefinition Height="Auto" /> <RowDefinition Height="*" />    <RowDefinition Height="Auto" /> <RowDefinition Height="Auto" /> <RowDefinition Height="Auto" /> </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="SISTEMA DE INSPECCIÓN TÉCNICA" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="ExtraBold" Margin="0,0,0,5"/>
            <TextBlock Text="GESTIÓN DE CITAS" Foreground="White" FontSize="32" FontWeight="Black"/>
            <Separator Background="#1A1A23" Margin="0,10,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#16161D" CornerRadius="10" Padding="15" Margin="0,0,15,0" BorderBrush="#222" BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="18"/>
                    <TextBox x:Name="TxtBuscar" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" Height="34" Background="#0A0A0C" Foreground="White" BorderBrush="#333" VerticalContentAlignment="Center" Padding="5,0" />

                    <Rectangle Width="1" Height="25" Fill="#333" Margin="25,0"/>

                    <TextBlock Text="DESDE:" Foreground="#555" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <DatePicker SelectedDate="{Binding FechaInicio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                Width="140" Height="34" 
                                Background="#1A1A23" BorderBrush="#333" VerticalAlignment="Center"/>

                    <TextBlock Text="HASTA:" Foreground="#555" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,12,0"/>
                    <DatePicker SelectedDate="{Binding FechaFin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                Width="140" Height="34" 
                                Background="#1A1A23" BorderBrush="#333" VerticalAlignment="Center"/>

                    <Rectangle Width="1" Height="25" Fill="#333" Margin="25,0"/>

                    <TextBlock Text="MOTOR:" Foreground="#555" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="CbFiltroMotor" 
                              SelectedValue="{Binding MotorSeleccionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                              SelectedValuePath="Content"
                              Width="130" Height="34" Background="#1A1A23">
                        <ComboBoxItem Content="TODOS" IsSelected="True"/>
                        <ComboBoxItem Content="GASOLINA"/>
                        <ComboBoxItem Content="DIÉSEL"/>
                        <ComboBoxItem Content="HÍBRIDO"/>
                        <ComboBoxItem Content="ELÉCTRICO"/>
                    </ComboBox>

                    <Rectangle Width="1" Height="25" Fill="#333" Margin="25,0"/>
                    <CheckBox IsChecked="{Binding MostrarEliminados}" 
                              Content="ELIMINADOS"
                              Foreground="{DynamicResource AccentBrush}"
                              FontWeight="Bold"
                              VerticalAlignment="Center"
                              Margin="5,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="#0F0F12" CornerRadius="10" BorderBrush="#1A1A23" BorderThickness="1" Margin="0,15,0,0">
           <DataGrid ItemsSource="{Binding Citas}" 
          SelectedItem="{Binding SelectedCita}" 
          AutoGenerateColumns="False" 
          Background="#0F0F12" 
          Foreground="White" 
          BorderThickness="0" 
          GridLinesVisibility="None" 
          CanUserAddRows="False" 
          IsReadOnly="True" 
          SelectionMode="Single"
          SelectionUnit="FullRow"
          HeadersVisibility="Column"
          FontSize="16" 
          RowHeight="50"
          MouseDoubleClick="OnCitaDoubleClick">

    <DataGrid.CellStyle>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="#0F0F12"/> 
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,0"/> 
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3300F2FF"/> 
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </DataGrid.CellStyle>

    <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#0F0F12"/> 
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#16161D"/> 
                </Trigger>
            </Style.Triggers>
        </Style>
    </DataGrid.RowStyle>

    <DataGrid.ColumnHeaderStyle>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#16161D"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontSize" Value="14"/> <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Padding" Value="15,12"/> 
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#222"/>
        </Style>
    </DataGrid.ColumnHeaderStyle>

    <DataGrid.Columns>
        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" />
        <DataGridTextColumn Header="DNI PROPIETARIO" Binding="{Binding DniPropietario}" Width="1.5*" />
        <DataGridTextColumn Header="MATRÍCULA" Binding="{Binding Matricula}" Width="1.5*"/>
        <DataGridTextColumn Header="MARCA" Binding="{Binding Marca}" Width="*"/>
        <DataGridTextColumn Header="MOTOR" Binding="{Binding Motor}" Width="*"/>
        <DataGridTextColumn Header="FECHA ITV" Binding="{Binding FechaItv, StringFormat=dd/MM/yyyy}" Width="1.2*"/>
        <DataGridTextColumn Header="INSPECCIÓN" Binding="{Binding FechaInspeccion, StringFormat=dd/MM/yyyy}" Width="1.2*"/>
    </DataGrid.Columns>
</DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Command="{Binding NewCommand}" Content="➕ NUEVO" Width="120" Height="45" Margin="0,0,15,0" Background="{DynamicResource AccentBrush}" Foreground="#0A0A0C" FontWeight="Black" BorderThickness="0">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
            </Button>
            <Button Command="{Binding ViewCommand}" Content="👁️ VER" Width="110" Height="45" Margin="0,0,15,0" Background="#16161D" Foreground="White" BorderBrush="#333">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
            </Button>
            <Button Command="{Binding EditCommand}" Content="✏️ EDITAR" Width="110" Height="45" Margin="0,0,15,0" Background="#16161D" Foreground="White" BorderBrush="#333">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
            </Button>
            <Button Command="{Binding DeleteCommand}" Content="🗑️ ELIMINAR" Width="110" Height="45" Background="#16161D" Foreground="#FF0055" BorderBrush="#441122">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
            </Button>
            <Button Command="{Binding RestoreCommand}" Content="↩️ RESTAURAR" Width="130" Height="45" Background="#16161D" Foreground="#00FF88" BorderBrush="#006644">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding MostrarEliminados}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <Border Grid.Row="4" Background="#16161D" CornerRadius="10" Padding="10" Margin="0,20,0,0" BorderBrush="#222" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding PrimeraPaginaCommand}" Content="⏮" Width="40" Height="30" Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderBrush="Transparent"/>
                <Button Command="{Binding PaginaAnteriorCommand}" Content="◀" Width="40" Height="30" Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderBrush="Transparent" Margin="0,0,10,0"/>
                <TextBlock Text="PÁGINA" Foreground="#555" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                <Border Background="{DynamicResource AccentBrush}" Margin="10,0" Padding="10,4" CornerRadius="4">
                    <TextBlock Text="{Binding PaginaActual}" Foreground="#0A0A0C" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="DE" Foreground="#555" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalPaginas}" Foreground="White" Margin="10,0" VerticalAlignment="Center" FontWeight="Bold"/>
                <Button Command="{Binding PaginaSiguienteCommand}" Content="▶" Width="40" Height="30" Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderBrush="Transparent" Margin="10,0,0,0"/>
                <Button Command="{Binding UltimaPaginaCommand}" Content="⏭" Width="40" Height="30" Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderBrush="Transparent"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="5" Margin="0,15,0,0">
            <Grid>
                <TextBlock Text="LUIS VIVES ITV - TERMINAL 01 v2.6" Foreground="#333" FontSize="10" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="8" Height="8" Fill="#00FF88" Margin="0,0,10,0"/>
                    <TextBlock Text="CONEXIÓN SEGURA" Foreground="#00FF88" FontSize="10" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>