<Window x:Class="GestionITVPro.WPF.Views.Cita.CitaEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Umbrella ITV - Configuración de Vehículo" 
        Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F12"
        AllowsTransparency="False" WindowStyle="ThreeDBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Título -->
            <RowDefinition Height="*"/>    <!-- Formulario -->
            <RowDefinition Height="Auto"/> <!-- Botones -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🛠️ MODIFICACIÓN DE LA CITA" FontSize="24" FontWeight="Black" Foreground="#00F2FF"/>
            <Rectangle Height="2" Fill="#00F2FF" Margin="0,5,0,0" HorizontalAlignment="Left" Width="100"/>
        </StackPanel>

        <!-- CUERPO DEL FORMULARIO -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                
                <!-- Fila 1: Propietario y Matrícula -->
                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="👤 DNI PROPIETARIO" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#333" Padding="5,7" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="🆔 MATRÍCULA" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#00F2FF" Padding="5,7" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>

                <!-- Fila 2: Marca y Modelo -->
                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="🏷️ MARCA" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#333" Padding="5,7"/>
                    </StackPanel>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="🚘 MODELO" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#333" Padding="5,7"/>
                    </StackPanel>
                </UniformGrid>

                <!-- Fila 3: Cilindrada y Motor -->
                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="⚡ CILINDRADA" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#333" Padding="5,7"/>
                    </StackPanel>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="⚙️ TIPO DE MOTOR" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox Height="35" Background="#1A1A23" BorderBrush="#333" Padding="5,2" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="⛽ Gasolina" IsSelected="True"/>
                            <ComboBoxItem Content="🛢️ Diésel"/>
                            <ComboBoxItem Content="🔌 Híbrido"/>
                            <ComboBoxItem Content="🔋 Eléctrico"/>
                        </ComboBox>
                    </StackPanel>
                </UniformGrid>

                <!-- Fila 4: Fechas -->
                <Border Background="#16161D" Padding="15" CornerRadius="10" BorderBrush="#222" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📅 CALENDARIO DE INSPECCIÓN" Foreground="#7000FF" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="🕒 FECHA DE INSPECCIÓN" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                        <DatePicker Margin="0,0,0,15" Height="35"/>

                        <TextBlock Text="📝 FECHA DE MATRICULACIÓN" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                        <DatePicker Height="35"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ACCIONES -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="❌ CANCELAR" Width="120" Height="40" Margin="0,0,10,0" 
                    Background="Transparent" Foreground="#FF5555" BorderBrush="#333" Cursor="Hand"/>
            
            <Button Content="💾 GUARDAR CAMBIOS" Width="170" Height="40" 
                    Background="#00F2FF" Foreground="Black" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>