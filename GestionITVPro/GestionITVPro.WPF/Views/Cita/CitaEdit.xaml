<Window x:Class="GestionITVPro.WPF.Views.Cita.CitaEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GestionITVPro.WPF.ViewModels.Citas"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="750" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#121212" Foreground="White"
        WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#00F2FF" BorderThickness="1" CornerRadius="15" Background="#1A1A1D">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="🛠" FontSize="30" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#00F2FF"/>
                <TextBlock Text="{Binding WindowTitle}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#00F2FF"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <UniformGrid Columns="2" Margin="0,0,0,15">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="👤 DNI PROPIETARIO" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.DniPropietario, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                     Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#444" Padding="5,7"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="🆔 MATRÍCULA" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.Matricula, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                     Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#444" Padding="5,7"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,15">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="🏷 MARCA" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.Marca, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                     Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#444" Padding="5,7"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="🚗 MODELO" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.Modelo, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                     Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#444" Padding="5,7"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,15">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="⚡ CILINDRADA" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.Cilindrada, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                     Height="35" Background="#1A1A23" Foreground="White" BorderBrush="#444" Padding="5,7"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="⚙ TIPO DE MOTOR" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding Motors}" 
                                      SelectedItem="{Binding FormData.Motor}"
                                      Height="35" Background="#1A1A23" Foreground="Black"/>
                        </StackPanel>
                    </UniformGrid>

                    <Border Background="#25252B" CornerRadius="10" Padding="15" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="🗓 CALENDARIO DE INSPECCIÓN" Foreground="#A044FF" FontWeight="Bold" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="🕒 FECHA DE INSPECCIÓN" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding FormData.FechaInspeccion, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Margin="0,0,0,15"/>

                            <TextBlock Text="📄 FECHA DE MATRICULACIÓN" Foreground="#777" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding FormData.FechaItv, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                        Margin="0,0,0,5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Command="{Binding CancelCommand}" Content="❌ CANCELAR" 
                        Width="120" Height="40" Margin="0,0,10,0" Cursor="Hand"
                        Background="#332222" Foreground="#FF5555" BorderThickness="1"/>
                <Button Command="{Binding SaveCommand}" Content="💾 GUARDAR CAMBIOS" 
                        Width="180" Height="40" Cursor="Hand"
                        Background="#00F2FF" Foreground="#121212" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>