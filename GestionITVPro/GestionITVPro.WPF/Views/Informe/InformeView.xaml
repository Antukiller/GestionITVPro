<Page x:Class="GestionITVPro.WPF.Views.Informe.InformeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Gestión ITV - Generación de Informes"
      Background="#0A0A0C">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. HEADER -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
            <iconPacks:PackIconMaterial Kind="FileChart" Width="40" Height="40" Foreground="{DynamicResource AccentBrush}"
                                        VerticalAlignment="Center" Margin="0,0,15,0" />
            <StackPanel>
                <TextBlock Text="MÓDULO DE IMPRESIÓN" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="ExtraBold"/>
                <TextBlock Text="Generación de Informes" Foreground="White" FontSize="28" FontWeight="Black"/>
            </StackPanel>
        </StackPanel>

        <!-- 2. FILTROS Y OPCIONES -->
        <Border Grid.Row="1" Background="#0F0F12" CornerRadius="10" Padding="20,15" Margin="0,0,0,25" BorderBrush="#1A1A23" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding IncluirCanceladas}" VerticalAlignment="Center" Margin="0,0,25,0">
                    <TextBlock Text="Incluir citas canceladas" Foreground="#AAA" Margin="5,0,0,0"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding SoloVehiculosEco}" VerticalAlignment="Center">
                    <TextBlock Text="Solo vehículos ECO / Eléctricos" Foreground="#AAA" Margin="5,0,0,0"/>
                </CheckBox>
                
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="20,0" Background="#333"/>
                
                <iconPacks:PackIconMaterial Kind="CalendarRange" Foreground="#555" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Periodo: Mes Actual" Foreground="#555" VerticalAlignment="Center" FontSize="11" FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- 3. REPORTE GRID (3 Columnas) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Bloque 1: Informe de Vehículos -->
            <GroupBox Grid.Column="0" Header="INFORME DE VEHÍCULOS" Margin="0,0,10,0"
                      BorderBrush="#1A1A23" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold">
                <StackPanel Margin="15">
                    <TextBlock Text="Listado técnico de vehículos registrados, incluyendo cilindrada y tipo de motor." 
                               TextWrapping="Wrap" Foreground="#888" Margin="0,0,0,20" Height="45"/>
                    
                    <Button Command="{Binding GenerarInformeVehiculosPdfCommand}" Height="45" Margin="0,0,0,10" Background="#16161D" BorderBrush="#222">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#FF4545"/>
                            <TextBlock Text="Descargar PDF" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GenerarInformeVehiculosHtmlCommand}" Height="45" Background="#16161D" BorderBrush="#222">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="LanguageHtml5" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#E44D26"/>
                            <TextBlock Text="Generar HTML" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </GroupBox>

            <!-- Bloque 2: Informe de Citas -->
            <GroupBox Grid.Column="1" Header="INFORME DE CITAS" Margin="10,0,10,0"
                      BorderBrush="#1A1A23" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold">
                <StackPanel Margin="15">
                    <TextBlock Text="Resumen detallado de citas programadas, estados y horas de inspección." 
                               TextWrapping="Wrap" Foreground="#888" Margin="0,0,0,20" Height="45"/>

                    <Button Command="{Binding GenerarInformeCitasPdfCommand}" Height="45" Margin="0,0,0,10" Background="#16161D" BorderBrush="#222">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#FF4545"/>
                            <TextBlock Text="Descargar PDF" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GenerarInformeCitasHtmlCommand}" Height="45" Background="#16161D" BorderBrush="#222">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="LanguageHtml5" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#E44D26"/>
                            <TextBlock Text="Generar HTML" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </GroupBox>

            <!-- Bloque 3: Rendimiento y Totales -->
            <GroupBox Grid.Column="2" Header="RENDIMIENTO GENERAL" Margin="10,0,0,0"
                      BorderBrush="#1A1A23" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold">
                <StackPanel Margin="15">
                    <TextBlock Text="Análisis estadístico de saturación, tiempos medios y comparativas mensuales." 
                               TextWrapping="Wrap" Foreground="#888" Margin="0,0,0,20" Height="45"/>

                    <Button Command="{Binding GenerarInformeRendimientoPdfCommand}" Height="45" Margin="0,0,0,10" Background="#16161D" BorderBrush="#222">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#FF4545"/>
                            <TextBlock Text="Descargar PDF" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GenerarInformeRendimientoHtmlCommand}" Height="45" Background="#16161D" BorderBrush="#222">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="LanguageHtml5" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#E44D26"/>
                            <TextBlock Text="Generar HTML" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- 4. STATUS BAR -->
        <Border Grid.Row="3" Background="#16161D" Padding="12,8" CornerRadius="5" Margin="0,20,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#AAA" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Listo para exportar" Foreground="#444" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>
