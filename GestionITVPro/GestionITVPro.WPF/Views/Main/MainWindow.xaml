<Window x:Class="GestionITVPro.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Umbrella ITV - Gestión de Datos Técnicos"
        Width="1500" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0C" Foreground="White"
        PreviewKeyDown="OnPreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- MENU SUPERIOR -->
        <Menu Grid.Row="0" Background="#16161D" Padding="10">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="Padding" Value="15,5"/>
                </Style>
            </Menu.Resources>
            <MenuItem Header="ARCHIVO">
                <MenuItem Header="Exportar (Ctrl+E)" Click="OnExportarClick" Foreground="Black"/>
                <Separator />
                <MenuItem Header="Salir (Alt+F4)" Click="OnSalirClick" Foreground="Black"/>
            </MenuItem>
            <MenuItem Header="GESTIÓN">
                <MenuItem Header="Citas" Click="OnCitasClick" Foreground="Black"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="#0F0F12" BorderBrush="#1A1A23" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">
                    <TextBlock Text="OPERACIONES" Foreground="#00F2FF" FontSize="11" FontWeight="Bold" Margin="10,0,0,15"/>
                    <Button Height="55" Background="#1A1A23" BorderThickness="0" Margin="0,5" Click="OnDashboardClick">
                        <StackPanel Orientation="Horizontal" Margin="15,0">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Foreground="White" Width="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="DASHBOARD" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Height="55" Background="#1A1A23" BorderThickness="0" Margin="0,5" Click="OnCitasClick">
                        <StackPanel Orientation="Horizontal" Margin="15,0">
                            <iconPacks:PackIconMaterial Kind="CalendarClock" Foreground="White" Width="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="GESTIÓN CITAS" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- CONTENIDO PRINCIPAL -->
            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="REGISTRO TÉCNICO" Foreground="White" FontSize="32" FontWeight="Black"/>
                        <TextBlock Text="BASE DE DATOS UMBRELLA" Foreground="#00F2FF" FontSize="13" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Bottom" Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="TrashCanOutline" Foreground="#FF4545" VerticalAlignment="Center" Margin="0,0 ..."/>
                        <CheckBox x:Name="ChkMostrarBorrados" Content="MOSTRAR REGISTROS ELIMINADOS" Foreground="White" VerticalContentAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </DockPanel>

                <!-- TABLA ESTILO BASE DE DATOS -->
                <Border Grid.Row="1" Background="#0F0F12" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
                    <DataGrid x:Name="DGVehiculos" 
                              ItemsSource="{Binding Vehiculos}"
                              Background="Transparent" Foreground="White" 
                              GridLinesVisibility="All" HorizontalGridLinesBrush="#333" VerticalGridLinesBrush="#333"
                              RowBackground="#0F0F12" AlternatingRowBackground="#16161D"
                              AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="45">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="55" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="MATRÍCULA" Width="100" Binding="{Binding Matricula}"/>
                            <DataGridTextColumn Header="MARCA" Width="100" Binding="{Binding Marca}"/>
                            <DataGridTextColumn Header="MODELO" Width="120" Binding="{Binding Modelo}"/>
                            <DataGridTextColumn Header="MOTOR" Width="100" Binding="{Binding Motor}"/>
                            <DataGridTextColumn Header="CILINDRADA" Width="100" Binding="{Binding Cilindrada}"/>
                            <DataGridTextColumn Header="F. MATRICULACIÓN" Width="140" Binding="{Binding FechaMatriculacion}"/>
                            <DataGridTextColumn Header="F. INSPECCIÓN" Width="130" Binding="{Binding FechaInspeccion}"/>
                            <DataGridTextColumn Header="PROPIETARIO" Width="*" Binding="{Binding Propietario}"/>
                            <DataGridTextColumn Header="ESTADO" Width="110" Binding="{Binding Estado}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- BOTONES DE ACCIÓN GRANDES -->
                <UniformGrid Grid.Row="2" Columns="4" Margin="0,25,0,0" Height="85">
                    <Button Margin="8" Background="White" BorderThickness="0" Click="OnCitasClick">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Plus" Foreground="Black" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="AÑADIR" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="8" Background="White" BorderThickness="0">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Pencil" Foreground="Black" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="EDITAR" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="8" Background="White" BorderThickness="0" Click="OnExportarClick">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="FileExport" Foreground="Black" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="EXPORTAR" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="8" Background="#FF3333" BorderThickness="0" Click="OnSalirClick">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Delete" Foreground="White" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="SALIR" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2" Background="#16161D" Foreground="White" Padding="8">
            <StatusBarItem Content="ESTADO: SISTEMA UMBRELLA ACTIVO" FontWeight="Bold"/>
        </StatusBar>
    </Grid>
</Window>