<Window x:Class="GestionITVPro.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="LUIS VIVES ITV - Gestión de Datos Técnicos"
        Width="1500" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0C" Foreground="White"
        PreviewKeyDown="OnPreviewKeyDown" 
        Focusable="True">

    <Window.Resources>
        <!-- Estilo para que los submenús tengan letra negra y se lean -->
        <Style x:Key="SubMenuTextStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="Black" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. MENÚ SUPERIOR -->
        <Menu Grid.Row="0" Background="#16161D" Padding="10">
            <MenuItem Header="ARCHIVO" Foreground="White">
                <MenuItem Header="Exportar" Click="OnExportarClick" Style="{StaticResource SubMenuTextStyle}"/>
                <MenuItem Header="Importar" Click="OnImportarClick" Style="{StaticResource SubMenuTextStyle}"/>
                <Separator Background="#333"/>
                <MenuItem Header="Salir" Click="OnSalirClick" Style="{StaticResource SubMenuTextStyle}"/>
            </MenuItem>
            <MenuItem Header="SISTEMA" Foreground="White">
                <MenuItem Header="Citas" Click="OnCitasClick" Style="{StaticResource SubMenuTextStyle}"/>
                <MenuItem Header="Informes" Click="OnInformesClick" Style="{StaticResource SubMenuTextStyle}"/>
                <MenuItem Header="Gráficos" Click="OnGraficosClick" Style="{StaticResource SubMenuTextStyle}"/>
                <MenuItem Header="Backup" Click="OnBackupClick" Style="{StaticResource SubMenuTextStyle}"/>
                <Separator Background="#333"/>
                <MenuItem Header="Configuración" Click="OnConfiguracionClick" Style="{StaticResource SubMenuTextStyle}"/>
                <MenuItem Header="Acerca de" Click="OnAcercaDeClick" Style="{StaticResource SubMenuTextStyle}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 2. SIDEBAR (Navegación Lateral) -->
            <Border Grid.Column="0" Background="#0F0F12" BorderBrush="#1A1A23" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">
                    <TextBlock Text="NAVEGACIÓN" Foreground="#00F2FF" FontSize="11" FontWeight="Bold" Margin="10,0,0,15"/>
                    
                    <Button Height="50" Background="#1A1A23" BorderThickness="0" Margin="0,5" 
                            Click="OnDashboardClick" ToolTip="Ver Estadísticas">
                        <StackPanel Orientation="Horizontal" Margin="15,0">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Foreground="White" Width="18" Margin="0,0,12,0"/>
                            <TextBlock Text="DASHBOARD" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Height="50" Background="#1A1A23" BorderThickness="0" Margin="0,5" 
                            Click="OnCitasClick" ToolTip="Gestión de Citas">
                        <StackPanel Orientation="Horizontal" Margin="15,0">
                            <iconPacks:PackIconMaterial Kind="CalendarAccount" Foreground="White" Width="18" Margin="0,0,12,0"/>
                            <TextBlock Text="CITAS" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 3. ZONA CENTRAL (Limpia, sin DataGrid duplicado) -->
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Cabecera -->
                    <RowDefinition Height="*"/>    <!-- Contenido (Frame) -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="SISTEMA DE GESTIÓN" Foreground="White" FontSize="24" FontWeight="Black"/>
                    <TextBlock Text="REGISTRO TÉCNICO DE VEHÍCULOS" Foreground="#00F2FF" FontSize="10" FontWeight="Bold"/>
                </StackPanel>

                <!-- El Frame ahora ocupa todo el centro y cargará tus vistas completas -->
                <Border Grid.Row="1" Background="#0F0F12" CornerRadius="8" BorderBrush="#1A1A23" BorderThickness="1">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
                </Border>
            </Grid>
        </Grid>

        <!-- 4. BARRA DE ESTADO -->
        <StatusBar Grid.Row="2" Background="#16161D" Foreground="#888" Padding="5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11"/>
            </StatusBarItem>
            <Separator Background="#444"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="DeleteTypeText" FontSize="11" Margin="0,0,10,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>