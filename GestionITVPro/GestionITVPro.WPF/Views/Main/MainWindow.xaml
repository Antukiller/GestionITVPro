<Window x:Class="GestionITVPro.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Umbrella ITV - Gestión de Datos Técnicos"
        Width="1500" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0C" Foreground="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Menú -->
            <RowDefinition Height="*" />    <!-- Cuerpo -->
            <RowDefinition Height="Auto" /> <!-- Estado -->
        </Grid.RowDefinitions>

        <!-- 1. MENÚ SUPERIOR -->
        <Menu Grid.Row="0" Background="#16161D" Padding="10">
            <MenuItem Header="ARCHIVO" Foreground="White">
                <MenuItem Header="Exportar" Command="{Binding NavigateToImportExportCommand}"/>
                <MenuItem Header="Salir" Command="{Binding SalirCommand}"/>
            </MenuItem>
            <MenuItem Header="SISTEMA" Foreground="White">
                <MenuItem Header="Backup" Command="{Binding NavigateToBackupCommand}"/>
                <MenuItem Header="Acerca de" Command="{Binding MostrarAcercaDeCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" /> <!-- Sidebar -->
                <ColumnDefinition Width="*" />   <!-- Contenido -->
            </Grid.ColumnDefinitions>

            <!-- 2. SIDEBAR -->
            <Border Grid.Column="0" Background="#0F0F12" BorderBrush="#1A1A23" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">
                    <TextBlock Text="NAVEGACIÓN" Foreground="#00F2FF" FontSize="11" FontWeight="Bold" Margin="10,0,0,15"/>
                    <Button Height="50" Background="#1A1A23" BorderThickness="0" Margin="0,5" 
                            Command="{Binding NavigateToDashboardCommand}" ToolTip="Ver Estadísticas">
                        <StackPanel Orientation="Horizontal" Margin="15,0">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Foreground="White" Width="18" Margin="0,0,12,0"/>
                            <TextBlock Text="DASHBOARD" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Agrega más botones aquí si lo deseas -->
                </StackPanel>
            </Border>

            <!-- 3. ZONA CENTRAL: TABLA + FRAME -->
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Cabecera -->
                    <RowDefinition Height="1.5*"/> <!-- TABLA FIJA -->
                    <RowDefinition Height="Auto"/> <!-- Divisor -->
                    <RowDefinition Height="1*"/>   <!-- CONTENIDO DINÁMICO -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="SISTEMA DE GESTIÓN" Foreground="White" FontSize="24" FontWeight="Black"/>
                    <TextBlock Text="REGISTRO TÉCNICO DE VEHÍCULOS" Foreground="#00F2FF" FontSize="10" FontWeight="Bold"/>
                </StackPanel>

                <!-- TABLA FIJA DE CITAS/VEHÍCULOS -->
                <Border Grid.Row="1" Background="#16161D" CornerRadius="8" BorderBrush="#1A1A23" BorderThickness="1">
                    <DataGrid ItemsSource="{Binding Citas}" AutoGenerateColumns="False" 
                              Background="Transparent" Foreground="White" RowBackground="#1A1A23" 
                              BorderThickness="0" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Matrícula" Binding="{Binding Matricula}" Width="100"/>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCita}" Width="150"/>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="*"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- El Splitter permite al usuario ajustar el tamaño de la tabla y el dashboard -->
                <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="#1A1A23" Margin="0,10"/>

                <!-- DASHBOARD O GRÁFICOS APARECEN AQUÍ -->
                <Border Grid.Row="3" Background="#0F0F12" CornerRadius="8" BorderBrush="#1A1A23" BorderThickness="1">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
                </Border>
            </Grid>
        </Grid>

        <!-- 4. BARRA DE ESTADO -->
        <StatusBar Grid.Row="2" Background="#16161D" Foreground="#888" Padding="5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>