<Window x:Class="GestionITVPro.WPF.Views.Splash.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cargando..." Height="300" Width="500"
        WindowStyle="None" 
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Border CornerRadius="20" Background="#1A1A1D" BorderBrush="#66FCF1" BorderThickness="2">
        <Grid>
            <StackPanel VerticalAlignment="Center" Margin="20">
                
                <!-- Título con tu estilo -->
                <TextBlock Text="ITV: Luis Vives" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           FontStyle="Italic"
                           Foreground="#66FCF1"
                           TextAlignment="Center" 
                           Margin="0,0,0,10"/>

                <!-- Tu frase mítica -->
                <TextBlock Text="La peor ITV en kilómetros. ¿Preparado para nuestras estafas?" 
                           FontSize="14" 
                           Foreground="White"
                           TextAlignment="Center" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,30"/>

                <!-- Barra de progreso moderna -->
                <ProgressBar x:Name="MiProgressBar" 
                             Height="10" 
                             Width="350"
                             Minimum="0" 
                             Maximum="100" 
                             Value="45" 
                             Foreground="#66FCF1"
                             Background="#4E4E50"
                             BorderThickness="0"/>
                
                <TextBlock Text="Cargando sistema de cobro injustificado..." 
                           FontSize="10" 
                           Foreground="Gray" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,0"/>
                
                
                <Button x:Name="BtnCancelar" 
                        Content="Abortar misión" 
                        Click="BtnCancelar_Click"
                        Width="140" 
                        Height="35"
                        Margin="0,20,0,0"
                        Background="#FF4B4B" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
    
                    <!-- Esta es la forma fácil de redondear un botón en WPF moderno -->
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>