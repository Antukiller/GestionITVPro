<Page x:Class="GestionITVPro.WPF.Views.Grafico.GraficoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d"
      Title="Estadísticas de Citas ITV"
      Background="#0A0A0C">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. HEADER (Panel Superior) -->
        <Border Grid.Row="0" Background="#0F0F12" BorderBrush="#1A1A23" BorderThickness="0,0,0,1">
            <DockPanel Margin="25,25,25,20">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <iconPacks:PackIconMaterial Kind="FileChart" Width="40" Height="40" Foreground="#00F2FF"
                                                VerticalAlignment="Center" Margin="0,0,15,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="INFORME DE GESTIÓN" Foreground="#00F2FF" FontSize="22" FontWeight="ExtraBold"/>
                        <TextBlock Text="ANÁLISIS DE CITAS Y VEHÍCULOS" Foreground="White" FontSize="28" FontWeight="Black" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Botón Refrescar integrado en el Header -->
                <Button Command="{Binding LoadStatisticsCommand}" 
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="#1A1A23" Foreground="#00F2FF" BorderBrush="#00F2FF"
                        Content="🔄 ACTUALIZAR" Padding="15,8" Cursor="Hand" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                    </Button.Resources>
                </Button>
            </DockPanel>
        </Border>

        <!-- 2. CONTENIDO SCROLLABLE -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20,25,25">
            <StackPanel>

                <!-- TARJETAS DE RESUMEN (Stats) -->
                <WrapPanel Margin="0,0,0,25">
                    <Border Background="#16161D" CornerRadius="10" Padding="20,15" Margin="0,0,15,15" MinWidth="185" BorderBrush="#222" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="TOTAL CITAS" Foreground="#555" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="{Binding TotalCitas}" Foreground="White" FontSize="24" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                    <Border Background="#16161D" CornerRadius="10" Padding="20,15" Margin="0,0,15,15" MinWidth="185" BorderBrush="#222" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="CITAS PARA HOY" Foreground="#00F2FF" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="{Binding CitasParaHoy}" Foreground="White" FontSize="24" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                    <Border Background="#16161D" CornerRadius="10" Padding="20,15" Margin="0,0,15,15" MinWidth="185" BorderBrush="#222" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="CILINDRADA MEDIA" Foreground="#555" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="{Binding CilindradaMedia, StringFormat='{}{0:F0} cc'}" Foreground="White" FontSize="24" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                    <Border Background="#16161D" CornerRadius="10" Padding="20,15" Margin="0,0,15,15" MinWidth="185" BorderBrush="#222" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="% VEHÍCULOS ECO" Foreground="#00FF88" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="{Binding PorcentajeVehiculosEco, StringFormat='{}{0:P1}'}" Foreground="White" FontSize="24" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- GRID DE GRÁFICOS PRINCIPALES -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" /> <!-- Espaciador -->
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" /> <!-- Espaciador -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- G1: TIPO DE MOTOR (Binding a MotorSeries) -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#0F0F12" CornerRadius="15" Padding="20" BorderBrush="#1A1A23" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="⛽ Desglose por Tipo de Motor" Foreground="#00F2FF" FontWeight="Bold" FontSize="14" Margin="5,0,0,30"/>
                            <lvc:PieChart Series="{Binding MotorSeries}" Height="450" LegendPosition="Right" />
                        </StackPanel>
                    </Border>

                    <!-- G2: CALENDARIO (Binding a CalendarioSeries y XAxes) -->
                    <Border Grid.Row="0" Grid.Column="2" Background="#0F0F12" CornerRadius="15" Padding="20" BorderBrush="#1A1A23" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="📅 Estado de Citas en Calendario" Foreground="#00F2FF" FontWeight="Bold" FontSize="14" Margin="5,0,0,60"/>
                            <lvc:CartesianChart Series="{Binding CalendarioSeries}" XAxes="{Binding XAxesCalendario}" Height="450" />
                        </StackPanel>
                    </Border>

                    <!-- G3: ANÁLISIS AMBIENTAL (Binding a EcoSeries) -->
                    <Border Grid.Row="2" Grid.Column="0" Background="#0F0F12" CornerRadius="15" Padding="20" BorderBrush="#1A1A23" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🌱 Análisis Ambiental (Eco vs Combustión)" Foreground="#00F2FF" FontWeight="Bold" Margin="5,0,0,15"/>
                            <lvc:PieChart Series="{Binding EcoSeries}" Height="300" />
                        </StackPanel>
                    </Border>

                    <!-- G4: CUADRO DE ESTADO OPERATIVO -->
                    <Border Grid.Row="2" Grid.Column="2" Background="#16161D" CornerRadius="15" Padding="20" BorderBrush="#00F2FF" BorderThickness="1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="CalendarClock" Width="48" Height="48" Foreground="#00F2FF" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="ÚLTIMA CITA PROGRAMADA" Foreground="#555" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding UltimaCitaProgramada, StringFormat='{}{0:dd/MM/yyyy}'}" Foreground="White" FontSize="22" FontWeight="Black" HorizontalAlignment="Center" Margin="0,5"/>
                            
                            <Border x:Name="BadgeStatus" Background="#3300F2FF" Padding="10,5" CornerRadius="5" Margin="0,15,0,0">
                                <TextBlock Text="{Binding StatusMessage}" Foreground="#00F2FF" FontWeight="Bold" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Espacio extra al final -->
                <Border Height="50" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>